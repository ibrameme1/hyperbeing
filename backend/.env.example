# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# Set to "production" to enable safe error responses (no stack traces in API responses)
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. Keep secret — never commit the real value.
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ─── AI API Keys ──────────────────────────────────────────────────────────────
# If absent, the server runs in mock mode (no real AI calls).
# Never expose these values client-side or commit them to version control.
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origin of the React frontend — used by CORS middleware to allow credentials.
FRONTEND_URL=http://localhost:5173
