# ── Core ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-in-production
SESSION_SECRET=                      # OAuth-redirect session only; falls back to JWT_SECRET
FRONTEND_URL=http://localhost:5173   # comma-separated list allowed (CORS + redirects)
API_URL=http://localhost:3001        # public URL of this API (OAuth callback base)
DB_PATH=                             # optional; default backend/data/hyperbeing.db
IMAGE_STORAGE_DIR=                    # where slide images are stored on disk; set to the persistent volume path in prod (e.g. /data/images). Default: <DB dir>/images
LOG_LEVEL=info                       # debug | info | warn | error

# ── AI providers (unset or "demo" = mock mode with placeholder output) ────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_IMAGE_MODEL=gpt-image-2

# ── Stripe (payments silently disabled when unset) ────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CLEANUP_ON_BOOT=              # set to "false" to skip the boot-time stale-subscription sweep
STRIPE_BASIC_PRICE_ID=
STRIPE_BASIC_ANNUAL_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ULTRA_T1_PRICE_ID=
STRIPE_ULTRA_T1_ANNUAL_PRICE_ID=
STRIPE_ULTRA_T2_PRICE_ID=
STRIPE_ULTRA_T2_ANNUAL_PRICE_ID=
STRIPE_ULTRA_T3_PRICE_ID=
STRIPE_ULTRA_T3_ANNUAL_PRICE_ID=
STRIPE_ULTRA_T4_PRICE_ID=
STRIPE_ULTRA_T4_ANNUAL_PRICE_ID=

# ── OAuth (each provider silently disabled when unset) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=                        # comma-separated; these accounts bypass credit/token limits
ADMIN_TOKEN=                         # static token for the /admin monitoring dashboard

# ── Email (Resend — silently disabled when unset) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=HyperBeing <hello@hyperbeing.co>
FEEDBACK_EMAIL=team@hyperbeing.co

# ── Observability (optional) ──────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
